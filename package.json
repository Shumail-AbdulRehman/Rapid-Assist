{
  "name": "roadside-assistance-platform",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "server"
  ],
  "scripts": {
    "db:pull": "docker pull mongo:7",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose stop mongodb",
    "db:logs": "docker compose logs -f mongodb",
    "db:shell": "docker compose exec mongodb mongosh roadside_app",
    "db:seed:demo": "node server/src/data/seedDemoAccounts.js",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:server": "npm --workspace server run dev",
    "lint:web": "npm --workspace apps/web run lint"
  }
}
